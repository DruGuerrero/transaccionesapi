              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroCuenta\": \"1234567890\",\n  \"saldo\": 1000,\n  \"titular\": \"Andres Guerrero\",\n  \"activa\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/cuentas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cuentas"
              ]
            },
            "description": "Crea una nueva cuenta para realizar transacciones."
          },
          "response": []
        },
        {
          "name": "Obtener Cuenta por ID",
          "request": {
            "method": "GET",
